DEFAULT_FROM_EMAIL=No@Re@Mc@26 <noreply@vibecopilot.ai>

# Local toggle:
# - true  -> print OTP mails in terminal
# - false -> use SMTP settings below
LOCAL_EMAIL_CONSOLE=false

# If EMAIL_BACKEND is omitted and EMAIL_HOST is set, Django will use SMTP.
# If both are omitted, Django falls back to console email backend.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@vibecopilot.ai
EMAIL_HOST_PASSWORD=replace-with-mailbox-password-or-app-password
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=10
